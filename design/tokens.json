{
  "$description": "Axion Designer 設計 token 唯一真相 (DTCG)。改色票/間距/字級/圓角只能改這裡；由 design/build-tokens.mjs 編譯成 styles/tokens.css。淺色為預設值，深色寫在 $extensions.modes.dark。這是通用、品牌中性的起始集——換品牌時只改這一份。",

  "color": {
    "$type": "color",

    "base": {
      "$description": "primitives — 只在此定義原始色，語意層一律 alias 到這裡",
      "ink-900":  { "$value": "#1d1d1f" },
      "ink-600":  { "$value": "#6e6e73" },
      "ink-400":  { "$value": "#86868b" },
      "paper-0":  { "$value": "#ffffff" },
      "paper-50": { "$value": "#f5f5f7" },
      "paper-100":{ "$value": "#fbfbfd" },
      "accent-500": { "$value": "#0071e3" },
      "accent-600": { "$value": "#0066cc" },
      "pos-500":  { "$value": "#147a4d" },
      "neg-500":  { "$value": "#cc2a1c" },
      "warn-600": { "$value": "#b25000" },
      "white":    { "$value": "#ffffff" }
    },

    "text": {
      "$description": "語意層 — 元件只用這一層，不直接碰 primitives",
      "primary":   { "$value": "{color.base.ink-900}",  "$extensions": { "modes": { "dark": "{color.base.paper-50}" } } },
      "secondary": { "$value": "{color.base.ink-600}",  "$extensions": { "modes": { "dark": "#a1a1a6" } } },
      "muted":     { "$value": "{color.base.ink-400}",  "$extensions": { "modes": { "dark": "#8a8a8f" } } },
      "on-accent": { "$value": "{color.base.white}" },
      "link":      { "$value": "{color.base.accent-600}", "$extensions": { "modes": { "dark": "#4aa3ff" } } }
    },
    "surface": {
      "page":   { "$value": "{color.base.paper-0}",   "$extensions": { "modes": { "dark": "#0b0b0c" } } },
      "subtle": { "$value": "{color.base.paper-50}",  "$extensions": { "modes": { "dark": "#161617" } } },
      "raised": { "$value": "{color.base.paper-100}", "$extensions": { "modes": { "dark": "#1c1c1e" } } }
    },
    "brand": {
      "accent": { "$value": "{color.base.accent-500}", "$description": "唯一品牌強調色，跨主題恆定（已驗證 white 文字達 AA）" }
    },
    "state": {
      "$description": "狀態色。primitive 存淺色安全值（在淺色表面達 WCAG AA 4.5:1）；深色模式偏亮的等效色以 modes.dark 覆寫（在深色表面達 AA）。單一 hex 無法同時滿足兩模式（淺底要夠深、深底要夠亮，luminance 上有死區），故與 text/surface 一樣採雙模式取值。",
      "positive": { "$value": "{color.base.pos-500}", "$extensions": { "modes": { "dark": "#1d9e63" } } },
      "negative": { "$value": "{color.base.neg-500}", "$extensions": { "modes": { "dark": "#f0503e" } } },
      "warning":  { "$value": "{color.base.warn-600}", "$extensions": { "modes": { "dark": "#d9720f" } } }
    },
    "border": {
      "subtle":  { "$value": "rgba(0,0,0,0.08)", "$extensions": { "modes": { "dark": "rgba(255,255,255,0.10)" } } },
      "default": { "$value": "rgba(0,0,0,0.12)", "$extensions": { "modes": { "dark": "rgba(255,255,255,0.16)" } } }
    }
  },

  "space": {
    "$type": "dimension",
    "0": { "$value": "0px" },  "1": { "$value": "4px" },  "2": { "$value": "8px" },
    "3": { "$value": "12px" }, "4": { "$value": "16px" }, "5": { "$value": "20px" },
    "6": { "$value": "24px" }, "8": { "$value": "32px" }, "10": { "$value": "40px" },
    "12": { "$value": "48px" },"16": { "$value": "64px" },"20": { "$value": "80px" },
    "30": { "$value": "120px" }
  },

  "radius": {
    "$type": "dimension",
    "sm": { "$value": "8px" }, "md": { "$value": "12px" }, "lg": { "$value": "18px" },
    "xl": { "$value": "24px" }, "2xl": { "$value": "32px" }, "pill": { "$value": "980px" }
  },

  "shadow": {
    "card":       { "$value": "0 4px 24px rgba(0,0,0,0.06)" },
    "card-hover": { "$value": "0 12px 40px rgba(0,0,0,0.10)" },
    "float":      { "$value": "0 30px 60px rgba(0,0,0,0.12)" }
  },

  "font": {
    "family": {
      "$type": "fontFamily",
      "base":    { "$value": "-apple-system, BlinkMacSystemFont, 'PingFang TC', 'Noto Sans TC', 'Segoe UI', system-ui, sans-serif" },
      "display": { "$value": "'Iowan Old Style', 'Palatino', 'Songti TC', Georgia, serif" },
      "mono":    { "$value": "ui-monospace, 'SF Mono', 'JetBrains Mono', Menlo, monospace" }
    },
    "size": {
      "$type": "dimension",
      "xs": { "$value": "0.8125rem" }, "sm": { "$value": "0.9375rem" }, "base": { "$value": "1rem" },
      "lg": { "$value": "1.125rem" }, "xl": { "$value": "1.5rem" }, "2xl": { "$value": "2rem" }, "3xl": { "$value": "3rem" }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": "400" }, "medium": { "$value": "500" }, "semibold": { "$value": "600" }, "bold": { "$value": "700" }
    },
    "leading": { "tight": { "$value": "1.1" }, "snug": { "$value": "1.3" }, "normal": { "$value": "1.5" } },
    "tracking": { "tight": { "$value": "-0.022em" }, "normal": { "$value": "0em" }, "wide": { "$value": "0.02em" } }
  },

  "motion": {
    "duration": { "fast": { "$value": "150ms" }, "base": { "$value": "250ms" }, "slow": { "$value": "600ms" } },
    "ease": { "standard": { "$value": "cubic-bezier(0.2, 0.7, 0.2, 1)" } }
  }
}
